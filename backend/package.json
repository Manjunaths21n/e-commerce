{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" run build",
    "dev": "pnpm --filter \"./packages/**\" run dev",
    "services:dev": "pnpm --filter \"*-service\" --filter \"api-gateway\" --parallel run dev",
    "user:dev": "pnpm --filter user-service run dev",
    "store:dev": "pnpm --filter store-service run dev",
    "order:dev": "pnpm --filter order-service run dev",
    "gateway:dev": "pnpm --filter api-gateway run dev",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
